############################################
# Django Core
############################################

SECRET_KEY=replace-me-with-generated-secret-key
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

############################################
# PostgreSQL (Docker Init + Django DB)
############################################

POSTGRES_DB=vigil_db
POSTGRES_USER=vigil_user
POSTGRES_PASSWORD=your_strong_db_password

DB_NAME=vigil_db
DB_USER=vigil_user
DB_PASSWORD=your_strong_db_password
DB_HOST=db
DB_PORT=5432

############################################
# Redis (Celery Broker / Cache)
############################################

REDIS_URL=redis://redis:6379/0

############################################
# Celery Configuration (optional explicitness)
############################################

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

############################################
# Email (SMTP)
############################################

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.tumpetech.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=no-reply@tumpetech.com
EMAIL_HOST_PASSWORD=replace-with-secure-password
DEFAULT_FROM_EMAIL=Vigil Monitor <no-reply@tumpetech.com>

############################################
# Alternative Email Provider (SendGrid)
############################################
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.your_sendgrid_api_key
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

############################################
# Optional: Security / Production Hardening
############################################

SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False